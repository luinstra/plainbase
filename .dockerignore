# Keep the Docker build context lean. The Dockerfile only COPYs:
#   gradlew, gradlew.bat, settings.gradle.kts, build.gradle.kts, gradle/,
#   server/, frontend/
# Everything below is either regenerated inside the build stage or never
# needed in the image.

# VCS + tool state
.git
.github
.gradle
.kotlin
.idea
.crew
.claude

# Build outputs (regenerated by the Gradle build stage)
build
**/build
frontend/dist

# Node toolchain + deps (gradle-node downloads/installs these in the build stage)
frontend/.node
frontend/node_modules

# Docs and fixtures (mounted at runtime via compose, never baked into the image)
*.md
fixtures

# Docker files themselves
Dockerfile
docker-compose.yml
.dockerignore
