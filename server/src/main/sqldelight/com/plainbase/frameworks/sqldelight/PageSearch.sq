-- FTS5 spike table proving the embedded search tier (SQLite FTS5, §5.6)
-- works through SQLDelight + xerial sqlite-jdbc. The production search schema
-- (section documents, generations) lands in Phase 2 in its own search.db.
CREATE VIRTUAL TABLE page_search USING fts5(
  title TEXT,
  body TEXT
);

insertPage:
INSERT INTO page_search(title, body)
VALUES (:title, :body);

search:
SELECT title
FROM page_search
WHERE page_search MATCH :query;
