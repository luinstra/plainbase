<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{24} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Operator-tunable via PLAINBASE_LOG_LEVEL (matches the PLAINBASE_* env config family). -->
    <root level="${PLAINBASE_LOG_LEVEL:-INFO}">
        <appender-ref ref="STDOUT"/>
    </root>

    <logger name="io.modelcontextprotocol" level="WARN"/>
</configuration>
