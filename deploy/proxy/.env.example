# Copy to deploy/proxy/.env and fill in. NEVER commit the real .env.
# The shared secret the proxy stamps + the app verifies (a long random value):
PLAINBASE_PROXY_SECRET=replace-with-a-long-random-secret
# Your IdP (oauth2-proxy OIDC):
OIDC_ISSUER_URL=https://your-idp.example.com
OAUTH2_PROXY_CLIENT_ID=replace-me
OAUTH2_PROXY_CLIENT_SECRET=replace-me
# 16/24/32 random bytes in URL-SAFE base64 (oauth2-proxy requires the url-safe alphabet, not standard
# base64), e.g. `openssl rand -base64 32 | tr -- '+/' '-_'`:
OAUTH2_PROXY_COOKIE_SECRET=replace-with-32-random-bytes-urlsafe-b64
